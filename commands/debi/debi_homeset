#!/usr/bin/env bash
set -euo pipefail

if [[ $# -ne 1 || " $* " == *" --help "* ]]; then
  echo "Usage: debi_homeset <path>" >&2
  exit 1
fi

appendorreplace() {
  local file="$1"
  local key="$2"
  local value="$3"
  if grep -q "^$key=" "$file"; then
    sudo sed -i "s|^$key=.*|$key=$value|" "$file"
  else
    echo "$key=$value" | sudo tee -a "$file" >/dev/null
  fi
}

path="$1"
mkdir -p "$path"

appendorreplace /etc/adduser.conf DHOME "$path"
# appendorreplace /etc/default/useradd HOME "$path"
