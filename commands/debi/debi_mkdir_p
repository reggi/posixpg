#!/usr/bin/env bash
set -euo pipefail

if [[ $# -lt 2 || $# -gt 3 || " $* " == *" --help "* ]]; then
  echo "Usage: debi_mkdir_p <as_user> <path> [mode]" >&2
  exit 1
fi

as_user="$1"
path="$2"
mode="${3:-}"

if [[ -n "$mode" ]]; then
  sudo -u "$as_user" mkdir -p -m "$mode" "$path"
else
  sudo -u "$as_user" mkdir -p "$path"
fi
